{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",          // ensures web compatibility
    "module": "ESNext",          // needed for web build
    "moduleResolution": "bundler",  // resolves modules correctly
    "jsx": "react-jsx",           // React 18 JSX transform
    "esModuleInterop": true,     // avoids tslib default issues
    "allowSyntheticDefaultImports": true, 
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}